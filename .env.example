# MongoDB Atlas — חובה /task-manager ב-URI
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/task-manager?retryWrites=true&w=majority
MONGODB_DB_NAME=task-manager

# סיסמת כניסה לאפליקציה (שרת בלבד — ללא NEXT_PUBLIC_)
APP_PASSWORD=your-secret-password

# מקומי
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# SMTP לשליחת התראות מתוך המערכת
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
MAIL_FROM=Task Manager <no-reply@example.com>

# Vercel Production
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
