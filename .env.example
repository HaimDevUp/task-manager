# MongoDB Atlas — חובה /task-manager ב-URI
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/task-manager?retryWrites=true&w=majority
MONGODB_DB_NAME=task-manager

# מצב production: true (ברירת מחדל) — הרשאות admin/employee לפי config/employees.ts
# מצב פיתוח: false — גישת אדמין לכולם; אופציונלי APP_PASSWORD לכניסה מהירה
APP_LIVE=true

# סיסמה כללית לפיתוח בלבד (כש-APP_LIVE=false). ב-live: לכל עובד = {אימייל לפני @}26 (למשל haim26)
APP_PASSWORD=your-secret-password

# מקומי
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# SMTP לשליחת התראות מתוך המערכת
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
MAIL_FROM=Task Manager <no-reply@example.com>

# Vercel Production
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
